  // Firestore security rules for the playoff hockey pool.
  // Paste this into Firebase Console → Firestore Database → Rules, then Publish.
  // Re-publish after any edits here.

  rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {
      function signedIn() {
        return request.auth != null;
      }
      function isCommissioner() {
        return signedIn()
          && request.auth.token.email == 'randyjones87@gmail.com';
      }
      function isDraftDelegate(year, participantUid) {
        let season = get(/databases/$(database)/documents/seasons/$(year)).data;
        return 'draftDelegates' in season
          && participantUid in season.draftDelegates
          && request.auth.uid in season.draftDelegates[participantUid];
      }

      // Season doc: public read (contains teamsPublic for the league page);
      // only commissioner writes.
      match /seasons/{year} {
        allow read: if true;
        allow create, update: if isCommissioner();
        allow delete: if false;

        // Participants: signed-in only (contains emails).
        match /participants/{uid} {
          allow read: if signedIn();
          allow create, update: if signedIn()
            && (request.auth.uid == uid || isCommissioner());
          allow delete: if isCommissioner();
        }

        // Draft picks: public read for the league page; writes still gated.
        match /draftPicks/{pickId} {
          allow read: if true;
          allow create: if signedIn()
            && (request.resource.data.participantUid == request.auth.uid
                || isDraftDelegate(year, request.resource.data.participantUid));
          allow update: if signedIn()
            && (resource.data.participantUid == request.auth.uid
                || isCommissioner()
                || isDraftDelegate(year, resource.data.participantUid));
          allow delete: if isCommissioner();
        }

        // Banked picks: self-create during mid-drafts; self-update to mark
        // as used when drafting with a banked pick.
        match /bankedPicks/{id} {
          allow read: if signedIn();
          allow create: if signedIn()
            && request.resource.data.participantUid == request.auth.uid;
          allow update: if signedIn()
            && (resource.data.participantUid == request.auth.uid || isCommissioner());
          allow delete: if isCommissioner();
        }
        match /bonusPoints/{id} {
          allow read: if true;
          allow write: if isCommissioner();
        }
        match /marketBias/{id} {
          allow read: if signedIn();
          allow write: if isCommissioner();
        }
        match /playerStats/{id} {
          allow read: if true;
          allow write: if isCommissioner();
        }
        match /regularSeasonStats/{id} {
          allow read: if signedIn();
          allow write: if isCommissioner();
        }
        // Audit log: commissioner appends; anyone signed in can read.
        // Entries are immutable once written.
        match /auditLog/{id} {
          allow read: if signedIn();
          allow create: if isCommissioner();
          allow update, delete: if false;
        }
      }

      // Shared NHL player roster — public read (names/positions/teams only);
      // commissioner writes.
      match /nhlPlayers/{id} {
        allow read: if true;
        allow write: if isCommissioner();
      }
    }
  }
