// Firestore security rules for the playoff hockey pool.
// Paste this into Firebase Console → Firestore Database → Rules, then Publish.
// Re-publish after any edits here.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isCommissioner() {
      return signedIn()
        && request.auth.token.email == 'randyjones87@gmail.com';
    }

    // Season doc: anyone signed in can read, only commissioner writes.
    match /seasons/{year} {
      allow read: if signedIn();
      allow create, update: if isCommissioner();
      allow delete: if false;

      // Participants: self-write pre-lock; commissioner can always edit.
      match /participants/{uid} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && (request.auth.uid == uid || isCommissioner());
        allow delete: if isCommissioner();
      }

      // Draft picks, banked picks, bonus points, stats — read-only from client
      // for now. Server routes (admin SDK) will handle writes in later phases.
      match /{subcollection}/{doc=**} {
        allow read: if signedIn();
        allow write: if isCommissioner();
      }
    }

    // Shared NHL player roster — commissioner syncs from NHL API.
    match /nhlPlayers/{id} {
      allow read: if signedIn();
      allow write: if isCommissioner();
    }
  }
}
